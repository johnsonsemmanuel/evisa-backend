# Sumsub Integration Configuration
# Copy these to your .env file and add your real API keys

# Enable/disable Sumsub integration
SUMSUB_ENABLED=true

# Your Sumsub API credentials (REPLACE WITH REAL VALUES)
SUMSUB_APP_TOKEN=prd:3LuQfxFWBRqwy1OcJ2ZUzLKt.EjWaDgJbUaYub5LkdaLvLyDMq9OP3QOo
SUMSUB_SECRET_KEY=0qYHjC6SowLppWLaTIRqgFk60TJiwT9m
SUMSUB_BASE_URL=https://api.sumsub.com

# Webhook secret for signature verification
SUMSUB_WEBHOOK_SECRET=your_webhook_secret_here

# Which visa tiers require Sumsub verification
SUMSUB_REQUIRED_TIERS=priority,express

# Enable Sumsub for ETA applications (optional)
SUMSUB_ETA_ENABLED=false

# API timeout settings
SUMSUB_TIMEOUT=30
SUMSUB_CONNECT_TIMEOUT=10
SUMSUB_MAX_RETRIES=3
SUMSUB_RETRY_DELAY=1000