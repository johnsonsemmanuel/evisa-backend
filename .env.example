# ============================================================
# GH EVISA PLATFORM — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in all values before deployment
# NEVER commit .env to version control
# ============================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
APP_NAME="Ghana eVisa Platform"
APP_ENV=production
# local | staging | production
APP_KEY=
# Generate with: php artisan key:generate
APP_DEBUG=false
# MUST be false in production
APP_URL=https://evisa.gov.gh
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_PREVIOUS_KEYS=
# Comma-separated previous APP_KEY values for key rotation
APP_MAINTENANCE_DRIVER=file
# file | database
APP_MAINTENANCE_STORE=database
# Where maintenance mode state is stored
DATA_RETENTION_ENABLED=false
# Enable automated data retention (e.g. PII purge)

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_URL=
# Full DSN (overrides host/port/database/user/pass if set)
DB_HOST=
# MySQL host (IP or hostname)
DB_PORT=3306
DB_DATABASE=evisa_production
DB_USERNAME=
DB_PASSWORD=
DB_SOCKET=
# Unix socket path (optional)
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true
# Audit connection: restricted user for audit logs (SELECT+INSERT only)
DB_AUDIT_USER=
DB_AUDIT_PASSWORD=
# See Security Audit Session 8
MYSQL_ATTR_SSL_CA=
# Path to CA cert for TLS (optional)

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
# phpredis | predis
REDIS_URL=
# Full Redis URL (overrides host/port/password if set)
REDIS_HOST=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_PREFIX=
# Optional key prefix (default: app name slug)
REDIS_PERSISTENT=false
REDIS_CLUSTER=redis
# Default connection (queue/cache when using redis)
REDIS_DB=0
# Queue / default connection DB number
REDIS_QUEUE_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=1
# If session driver is redis
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000

# ---------------------------------------------------------------------------
# MAIL
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
# smtp | mailgun | ses | sendgrid | log
MAIL_SCHEME=
MAIL_URL=
# Full mail DSN (overrides host/port/user/pass if set)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# tls | ssl | null
MAIL_EHLO_DOMAIN=
# Optional EHLO domain (default: APP_URL host)
MAIL_SENDMAIL_PATH=/usr/sbin/sendmail -bs -i
MAIL_LOG_CHANNEL=
# Channel when MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@evisa.gov.gh
MAIL_FROM_NAME="Ghana eVisa Service"

# ---------------------------------------------------------------------------
# GCB PAYMENT GATEWAY (PRIMARY — required for visa payments)
# ---------------------------------------------------------------------------
GCB_MERCHANT_ID=
# REQUIRED — Obtain from GCB Bank integration team. Service fails fast if missing.
GCB_SECRET_KEY=
# HMAC signing key (or use GCB_API_KEY if your integration uses it)
GCB_API_KEY=
# Alternative: API key (used by config/services.php)
GCB_BASE_URL=
# GCB API base URL (e.g. https://epayuat.gcbltd.com:98/paymentgateway)
GCB_WEBHOOK_SECRET=
# Webhook HMAC secret
GCB_ALLOWED_IPS=
# Comma-separated IPs allowed for webhooks (optional)
GCB_BANK_ACCOUNT_NUMBER=
GCB_BANK_NAME=Ghana Commercial Bank
GCB_ACCOUNT_NAME=Ghana Immigration Service - eVisa
GCB_BRANCH=Accra Main Branch
GCB_SWIFT_CODE=GHCBGHAC
GCB_ENVIRONMENT=production
# sandbox | production

# ---------------------------------------------------------------------------
# PAYSTACK (fallback gateway)
# ---------------------------------------------------------------------------
PAYSTACK_PUBLIC_KEY=pk_live_
# Safe for frontend
PAYSTACK_SECRET_KEY=sk_live_
# NEVER expose to frontend
PAYSTACK_MERCHANT_EMAIL=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_SECRET=
# For webhook signature verification

# ---------------------------------------------------------------------------
# STRIPE (optional gateway)
# ---------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# SUMSUB (Identity Verification / KYC)
# ---------------------------------------------------------------------------
SUMSUB_ENABLED=false
SUMSUB_APP_TOKEN=
# From Sumsub dashboard
SUMSUB_SECRET_KEY=
# For request signing
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_WEBHOOK_SECRET=
# For webhook verification
SUMSUB_REQUIRED_TIERS=priority,express
# Comma-separated tiers that require verification
SUMSUB_ETA_ENABLED=false
SUMSUB_TIMEOUT=30
SUMSUB_CONNECT_TIMEOUT=10
SUMSUB_MAX_RETRIES=3
SUMSUB_RETRY_DELAY=1000
# Milliseconds

# ---------------------------------------------------------------------------
# AEROPASS (Interpol Nominal Check)
# ---------------------------------------------------------------------------
AEROPASS_BASE_URL=
# From Aeropass ICD documentation
AEROPASS_USERNAME=
# Basic auth username
AEROPASS_PASSWORD=
# Basic auth password
AEROPASS_API_USERNAME=
# For incoming requests from Aeropass (callback auth)
AEROPASS_API_PASSWORD=
AEROPASS_CALLBACK_URL=
# Your callback endpoint for async results (if required)
AEROPASS_TIMEOUT=20
# Seconds
AEROPASS_TIMEOUT_SECONDS=30
# Alternative key name used in some docs
AEROPASS_RETRY_DELAY=2
AEROPASS_MAX_RETRIES=3
AEROPASS_ENABLED=false

# ---------------------------------------------------------------------------
# BROADCASTING (Pusher) — real-time application/payment/officer updates
# ---------------------------------------------------------------------------
BROADCAST_DRIVER=log
# log (when Pusher not configured) | pusher | ably | null
PUSHER_APP_ID=
PUSHER_APP_KEY=
# Safe for frontend (set NEXT_PUBLIC_PUSHER_APP_KEY in frontend .env)
PUSHER_APP_SECRET=
# NEVER expose to frontend
PUSHER_APP_CLUSTER=eu
# e.g. eu | ap1 | us2
PUSHER_HOST=
# Override host (default: api-{cluster}.pusherapp.com)
PUSHER_PORT=443
PUSHER_SCHEME=https
ABLY_KEY=
# If using Ably instead of Pusher

# ---------------------------------------------------------------------------
# SANCTUM / AUTH
# ---------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=
# Comma-separated domains for SPA cookie auth (e.g. evisa.gov.gh)
SANCTUM_TOKEN_EXPIRY_MINUTES=480
# 8 hours for applicants
SANCTUM_OFFICER_TOKEN_EXPIRY_MINUTES=240
# 4 hours for officers
SANCTUM_TOKEN_PREFIX=
# Optional prefix for API tokens
TOKEN_EXPIRATION_MINUTES=60
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ---------------------------------------------------------------------------
# SECURITY
# ---------------------------------------------------------------------------
BLIND_INDEX_KEY=
# Separate key for PII blind indexes — see Security Audit
SCAN_UPLOADS_FOR_MALWARE=false
ADMIN_IP_WHITELIST=
# Comma-separated IPs for admin access (optional)
API_IP_BLACKLIST=
ENABLE_GEO_BLOCKING=false
SECURITY_ALERT_EMAIL=
SECURITY_ALERT_SMS=

# ---------------------------------------------------------------------------
# BORDER / BAC / AUDIT
# ---------------------------------------------------------------------------
BAC_EXPIRY_HOURS=24
BORDER_VERIFICATION_RATE_LIMIT=60
# Requests per minute
AUDIT_LOG_RETENTION_YEARS=7

# ---------------------------------------------------------------------------
# SESSION
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
# file | database | redis | cookie
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_CONNECTION=
# Redis connection name if SESSION_DRIVER=redis
SESSION_TABLE=sessions
SESSION_STORE=
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=
# true in production over HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

# ---------------------------------------------------------------------------
# QUEUE
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=redis
# sync | database | redis | sqs
QUEUE_FAILED_DRIVER=database-uuids
# database-uuids | dynamodb | file | null
DB_QUEUE_CONNECTION=
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
BEANSTALKD_QUEUE_HOST=localhost
BEANSTALKD_QUEUE=default
BEANSTALKD_QUEUE_RETRY_AFTER=90
SQS_PREFIX=
SQS_QUEUE=default
SQS_SUFFIX=

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
# debug | info | notice | warning | error | critical | alert | emergency
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_STACK=single
# Comma-separated channels for stack
LOG_DAILY_DAYS=14
LOG_SLACK_WEBHOOK_URL=
# For error alerting (optional)
LOG_SLACK_USERNAME=Laravel Log
LOG_SLACK_EMOJI=:boom:
LOG_PAPERTRAIL_HANDLER=
PAPERTRAIL_URL=
PAPERTRAIL_PORT=
LOG_STDERR_FORMATTER=
LOG_SYSLOG_FACILITY=LOG_USER
SENTRY_LARAVEL_DSN=
# Sentry error tracking (optional)

# ---------------------------------------------------------------------------
# FILESYSTEM / AWS (backups, storage)
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local
# local | s3 | public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
# For S3-compatible backends

# ---------------------------------------------------------------------------
# CORS / FRONTEND
# ---------------------------------------------------------------------------
FRONTEND_URL=https://evisa.gov.gh
# Allowed origin for CORS (e.g. https://evisa.gov.gh or http://localhost:3000)

# ---------------------------------------------------------------------------
# FRONTEND (Next.js — only NEXT_PUBLIC_ prefix is exposed to browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://evisa.gov.gh/api
NEXT_PUBLIC_PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_CLUSTER=

# ---------------------------------------------------------------------------
# BACKUP
# ---------------------------------------------------------------------------
BACKUP_STORAGE_DISK=s3
# Where to store database backups (s3 | local)
BACKUP_ENCRYPTION_PASSWORD=
# Encrypt backup archives (required for backup + restore test)
BACKUP_S3_BUCKET=
# S3 bucket for off-site backups (can match AWS_BUCKET or use dedicated bucket)
BACKUP_DIR=/var/backups/evisa
# Local backup directory (30-day retention)
BACKUP_RETENTION_DAYS_LOCAL=30
BACKUP_RETENTION_DAYS_OFFSITE=365

# Test database for weekly restore test (must exist; dedicated DB, not production)
DB_TEST_DATABASE=evisa_restore_test
DB_TEST_HOST=
# Defaults to DB_HOST if empty
DB_TEST_USERNAME=
DB_TEST_PASSWORD=
# Default to DB_USERNAME / DB_PASSWORD if empty

# ---------------------------------------------------------------------------
# SEEDING / DEV (do not use in production)
# ---------------------------------------------------------------------------
DEFAULT_OFFICER_PASSWORD=
# Only for seeders; change after first login
DEFAULT_APPLICANT_PASSWORD=
# Only for seeders

# ---------------------------------------------------------------------------
# PASSPORT VERIFICATION (US/UK/NG — optional)
# ---------------------------------------------------------------------------
US_PASSPORT_API_URL=https://api.state.gov/passport/verify
US_PASSPORT_API_KEY=
UK_PASSPORT_API_URL=https://api.gov.uk/passport/verify
UK_PASSPORT_API_KEY=
NG_PASSPORT_API_URL=https://api.immigration.gov.ng/passport/verify
NG_PASSPORT_API_KEY=

# ---------------------------------------------------------------------------
# OTHER SERVICES (optional)
# ---------------------------------------------------------------------------
POSTMARK_TOKEN=
RESEND_KEY=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
